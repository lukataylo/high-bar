{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "STRIPE_PUBLISHABLE_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_CONNECT_CLIENT_ID",
    "MODEL_BASE_URL",
    "MODEL_API_KEY",
    "ANTHROPIC_API_KEY",
    "RAILWAY_TOKEN",
    "DATABASE_URL",
    "REDIS_URL",
    "AUTH_SECRET",
    "PAYOUT_APPROVAL_THRESHOLD",
    "PAYOUT_DAILY_CAP",
    "AGENT_KILL_SWITCH"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
