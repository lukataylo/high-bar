# Secrets — never commit
.env
.env.*
!.env.example

# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
.turbo/
out/
coverage/
*.tsbuildinfo

# Local runtime data (autonomous-loop generated; reproducible via `node scripts/autonomous-loop.mjs --seed`)
data/

# NOTE: railway.json (the agent-loop start command) is intentionally left
# UNTRACKED but NOT ignored — `railway up` respects .gitignore, so ignoring it
# would drop it from the loop deploy. Do not `git add` it (it would override the
# GitHub-sourced web service's build/start config).

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
