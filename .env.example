# ============================================================
# High Bar — Expert Network  ·  ENV TEMPLATE (safe to commit)
# Copy to .env and fill in real values. .env is git-ignored.
# ============================================================

# --- Stripe (test mode) ---
# Keys: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Model backend for the Hermes agent loop (OpenAI-compatible) ---
MODEL_BASE_URL=
MODEL_API_KEY=
# Optional: route Hermes to Claude instead of an OpenAI-compatible endpoint
ANTHROPIC_API_KEY=

# --- Railway (deploy) ---
RAILWAY_TOKEN=

# --- Datastores (Railway provisions these; paste connection strings) ---
DATABASE_URL=
REDIS_URL=

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Agent / money-movement guardrails ---
# Payouts above this (USD) require human approval in the inbox
PAYOUT_APPROVAL_THRESHOLD=100
# Hard daily ceiling on agent-initiated payouts (USD)
PAYOUT_DAILY_CAP=1000
# Global kill switch for the autonomous loop (true = halt)
AGENT_KILL_SWITCH=false

# LinkedIn: no keys needed — outreach is DRAFT-ONLY, you send manually.
